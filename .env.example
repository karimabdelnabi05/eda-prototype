# =============================================================================
# EDA Prototype — Environment Variables
# =============================================================================

# Primary LLM Provider (Google Gemini — uses your GCP credits)
GOOGLE_API_KEY="your_gemini_api_key_here"
# Or use Vertex AI:
# GCP_PROJECT_ID="your_project_id"
# GCP_LOCATION="us-central1"

# Optional: Alternative LLM Providers
# OPENAI_API_KEY="your_openai_api_key_here"
# ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Compiler Settings
EDA_COMPILER_MODEL="gemini-2.0-flash"        # Model for compilation (needs strong coding)
EDA_ROUTER_MODEL="gemini-2.0-flash-lite"     # Model for query routing (fast + cheap)
EDA_MAX_RETRIES=3                              # Max validation loop retries
EDA_SANDBOX_TIMEOUT=30                         # Seconds before sandbox execution times out

# Artifact Storage
EDA_ARTIFACTS_DIR="./artifacts"                # Where compiled Python files are stored
